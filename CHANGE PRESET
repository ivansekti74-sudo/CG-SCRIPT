-- ========== 7. FUNGSI WALKSPEED ==========
local function setWalkSpeed(speed)
    local character = player.Character
    if character and character:FindFirstChild("Humanoid") then
        character.Humanoid.WalkSpeed = speed
        currentSpeedLabel.Text = "Current: " .. speed
    end
end

-- Fungsi untuk mengambil nilai dari slider dan mengaplikasikannya
local function applySpeedFromInput()
    local speed = tonumber(slider.Text)
    if speed then
        setWalkSpeed(speed)
    else
        slider.Text = tostring(DEFAULT_WALKSPEED)
        setWalkSpeed(DEFAULT_WALKSPEED)
    end
end

-- Tombol Set
setSpeedBtn.MouseButton1Click:Connect(applySpeedFromInput)

-- Enter pada TextBox
slider.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        applySpeedFromInput()
    end
end)

-- SHORTCUT KEYBOARD: Tekan "R" untuk apply speed
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    -- gameProcessed true berarti sedang mengetik di chat atau GUI input, agar tidak mengganggu
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.R then
        applySpeedFromInput()
    end
end)

-- Set default speed saat karakter muncul
local function onCharacterAdded(character)
