-- ========== 8. FUNGSI SWITCH EQUIPMENT (TANPA STATUE) ==========
local function switchSet(slotNumber, isTankerSet)
    if busy then return end
    busy = true
    
    if isTankerSet then
        tankerBtn.Text = "Switching..."
    else
        dmgBtn.Text = "Switching..."
    end
    
    switchRelicEvent:FireServer(slotNumber, 1)
    task.wait(0.3)
    switchRuneEvent:FireServer(slotNumber, 1)
    task.wait(0.3)
    switchDecorEvent:FireServer(slotNumber, 1)
    task.wait(0.3)
    SwitchSkillEvent:FireServer(slotNumber, 1)
    task.wait(0.3)
    
    expSet = isTankerSet
    if isTankerSet then
        tankerBtn.Text = "Tanker Set"
        dmgBtn.Text = "Damage Set"
        equipStatus.Text = "Status: Tanker Set (Slot " .. slotNumber .. ")"
    else
        tankerBtn.Text = "Tanker Set"
        dmgBtn.Text = "Damage Set"
        equipStatus.Text = "Status: Damage Set (Slot " .. slotNumber .. ")"
    end
    busy = false
end

tankerBtn.MouseButton1Click:Connect(function()
    if not busy and not expSet then
        switchSet(TANKER_SLOT, true)
    end
end)

dmgBtn.MouseButton1Click:Connect(function()
    if not busy and expSet then
        switchSet(DAMAGE_SLOT, false)
    end
end)

expSet = true
equipStatus.Text = "Status: Tanker Set (Slot " .. TANKER_SLOT .. ")"

-- ========== 9. EFEK HOVER ==========
local function addHoverEffect(btn, hoverColor, normalColor)
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = hoverColor
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = normalColor
    end)
end

