-- ========== SKILL LOOP ==========
local function skillLoop()
    task.spawn(function()
        local slot = 1
        while skillLoopEnabled do
            local char = player.Character or player.CharacterAdded:Wait()
            local hrp = char:WaitForChild("HumanoidRootPart")

            -- Reset semua slot
            ResetSlotRemote:FireServer()
            task.wait(SKILL_DELAY)

            -- Equip skill ID yang sedang aktif (dari TextBox)
            EquipSkillRemote:FireServer(skillId, slot)
            task.wait(0.5)

            -- Gunakan skill
            pressKey(SLOT_KEY_MAP[slot])
            task.wait(SKILL_ACTIVE_DURATION)

            slot += 1
            if slot > 3 then slot = 1 end
        end
    end)
end

-- ========== TP ENEMY LOOP ==========
local function tpEnemyLoop()
    task.spawn(function()
        local lockedPosition = nil
        local locked = false
        local lastTPPosition = nil

        local function median(t)
            table.sort(t)
            local n = #t
            if n == 0 then return nil end
            if n % 2 == 1 then
                return t[math.ceil(n / 2)]
            else
                return (t[n/2] + t[n/2 + 1]) / 2
            end
        end

        while tpLoopEnabled do
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if hrp then
                if not locked then
                    local enemyFolder = workspace:WaitForChild("\229\141\149\228\189\141\229\175\185\232\177\161")
                    local monsters = {}
                    local xs, zs = {}, {}

                    for _, enemy in ipairs(enemyFolder:GetChildren()) do
                        local eHRP = enemy:FindFirstChild("HumanoidRootPart")
                        local hum = enemy:FindFirstChildOfClass("Humanoid")
                        if eHRP and hum and hum.Health > 0 then
                            local dist = (hrp.Position - eHRP.Position).Magnitude
                            if dist <= DETECT_RADIUS then
                                table.insert(monsters, enemy)
                                table.insert(xs, eHRP.Position.X)
                                table.insert(zs, eHRP.Position.Z)
                            end
                        end
                    end

                    if #monsters > 0 then
                        local midX = median(xs)
                        local midZ = median(zs)
                        local pick, minDist = nil, math.huge
                        for _, enemy in ipairs(monsters) do
                            local pos = enemy.HumanoidRootPart.Position
                            local d = (Vector3.new(midX, pos.Y, midZ) - pos).Magnitude
                            if d < minDist then
                                minDist = d
                                pick = enemy
                            end
                        end
                        if pick then
                            lockedPosition = pick.HumanoidRootPart.Position
                            lastTPPosition = nil
                            DetectEnemyRemote:FireServer(pick)
                            locked = true
                        end
                    end
                end

                if lockedPosition then
                    local targetPos = lockedPosition + Vector3.new(0, 0, -3)
                    local playerDist = (hrp.Position - targetPos).Magnitude
                    if playerDist >= FORCE_RETURN_DISTANCE or playerDist >= RETURN_THRESHOLD or (lastTPPosition and (targetPos - lastTPPosition).Magnitude >= MOVE_THRESHOLD) then
                        hrp.CFrame = CFrame.new(targetPos)
                        lastTPPosition = targetPos
                    elseif not lastTPPosition then
                        hrp.CFrame = CFrame.new(targetPos)
                        lastTPPosition = targetPos
                    end
                end
            end
            task.wait(TP_DELAY)
        end
        locked = false
        lockedPosition = nil
        lastTPPosition = nil
    end)
end

